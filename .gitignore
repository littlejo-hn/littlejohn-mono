# contracts is its own repo (preserves pristine-master diff-transparency); aerodrome is a reference clone
contracts/
aerodrome-reference/

# SECRETS — never commit
.env
**/.env
*.local

# deps / build output
node_modules/
# also catch symlinked node_modules (e.g. launchpad/harness -> app/node_modules)
node_modules
dist/
**/*.b64

# foundry build output (launchpad) — never commit artifacts or lib/ gitlinks
launchpad/out/
launchpad/cache/
launchpad/broadcast/
launchpad/lib/

# os
.DS_Store
.dev.vars
.wrangler/
