# Copy to .env and fill. PRIVATE_KEY is read from the repo-root ../.env normally;
# duplicate it here if you run forge from this dir without sourcing that.

# --- deployer ---
PRIVATE_KEY=

# --- launchpad init params ---
# OWNER: on TESTNET the deployer is fine; on MAINNET this MUST be the governance multisig
# (owns the beacon + the UUPS upgrade key = the admin path to curve ETH).
OWNER=0xC7588c859e088592dd74459a94BE48E162346a50
# FEE_RECIPIENT: protocol / creation / migration fee sink (treasury).
FEE_RECIPIENT=0xC7588c859e088592dd74459a94BE48E162346a50

# --- LittleJohn DEX graduation venue (LIVE testnet 46630) ---
LJ_ROUTER=0x139D245cBe54dC332BbAf6191269b81D727466a8

# --- optional curve params (defaults in Deploy.s.sol) ---
# PROTOCOL_FEE_BPS=95
# CREATOR_FEE_BPS=30
# CREATION_FEE_WEI=0
# INITIAL_VIRTUAL_ETH_WEI=1000000000000000000
# MIGRATION_FEE_WEI=200000000000000000
