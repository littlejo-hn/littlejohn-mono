# Copy to .env.local and fill in. NEVER commit .env.local (RPC keys are secrets).

# One or more RPC endpoints, comma-separated for failover. Server-side only.
# Launch pairing: Alchemy (paid) first, public RH RPC as the free fallback.
#   PONDER_RPC_URL=https://<alchemy>,https://rpc.testnet.chain.robinhood.com
PONDER_RPC_URL=https://rpc.testnet.chain.robinhood.com

# Chain + launchpad (testnet defaults shown; swap for mainnet at cutover).
PONDER_CHAIN_ID=46630
LAUNCHPAD_ADDRESS=0xbABeA7f2e54dF349De3D743B9d55C33E6484cBD3
LAUNCHPAD_START_BLOCK=90397141
WETH_ADDRESS=0xF13E5952780Cdcd2C17333129b5Bc5187ff07DC2

# Realtime polling cadence (ms). Lower = fresher, more RPC load.
PONDER_POLLING_INTERVAL_MS=1000

# Postgres for prod (leave unset locally to use the bundled PGlite dev store).
# DATABASE_URL=postgresql://user:pass@host:5432/littlejohn
